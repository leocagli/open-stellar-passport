{
  "name": "@open-stellar/agent-passport",
  "version": "0.1.0",
  "description": "Client-side ZK proving + typed Soroban client for the Agent Passport — a zero-knowledge credential gating autonomous AI-agent payments on Stellar.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "example:register": "node --loader ts-node/esm examples/register.ts"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^16.0.1",
    "buffer": "6.0.3",
    "snarkjs": "^0.7.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "bfj": "9.1.3",
    "esbuild": "0.28.1"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/leocagli/open-stellar-passport.git",
    "directory": "sdk"
  },
  "keywords": [
    "stellar",
    "soroban",
    "zero-knowledge",
    "zk",
    "groth16",
    "sdk",
    "agent-passport",
    "x402"
  ],
  "author": "Leo Cagli",
  "engines": {
    "node": ">=20"
  }
}
